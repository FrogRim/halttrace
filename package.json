{
  "name": "halttrace",
  "version": "0.2.0",
  "description": "Local backtraces for halted coding-agent sessions.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "halttrace": "./dist/src/cli/main.js",
    "halttrace-latest": "./dist/src/cli/latest.js",
    "halttrace-explain": "./dist/src/cli/explain.js",
    "halttrace-handoff": "./dist/src/cli/handoff.js",
    "halttrace-doctor": "./dist/src/cli/doctor.js",
    "halttrace-claude": "./dist/src/cli/claude-hook.js",
    "halttrace-codex": "./dist/src/cli/codex-hook.js"
  },
  "files": [
    "dist/src/",
    "plugins/",
    "docs/",
    "examples/",
    "scripts/halttrace-powershell-aliases.psm1",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-claude-plugin.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node scripts/run-tests.mjs",
    "prepare": "npm run build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
